{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(.venv/bin/python:*)",
      "Bash(.venv/bin/python -m pytest:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(uv venv:*)",
      "Bash(uv pip:*)",
      "Bash(uv run:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)"
    ],
    "deny": []
  }
}
