# ============================================================================
# RAGSpine —— Docker Compose 环境变量样例。复制为 deploy/.env 后按需取消注释并填值。
#
#   cp deploy/.env.example deploy/.env
#
# RAGSPINE_* 注入到现成的 ServiceConfig（src/ragspine/service/config.py），不引入任何新配置系统。
# 例外：RAGSPINE_PG_URL（由 pgvector adapter 直接读环境，非 ServiceConfig 旋钮）与 RAGSPINE_PG_PASSWORD
#（compose-only 插值，仅喂内置 postgres 容器密码）——见各自行内说明。默认离线精简栈（mock provider
# + sqlite_vec，无需任何 API key）开箱即跑——此文件【整份保持注释】也能 `docker compose up`，
# 仅在接真实后端 / LLM 时才取消注释。
#
# 重要：给变量赋【空串】会覆盖代码里的默认值（env.get 见到空串不回退默认，且某些字段空串会报错，
#       如 RAGSPINE_REFERENCE_DATE=""）。所以【不需要的项一律保持注释】，需要时再取消注释填真值。
#
# 优先级：config 旋钮（PROVIDER / VECTOR_STORE / EMBEDDING / ...）走 compose 的 ${VAR} 插值，
#         需用 `--env-file deploy/.env` 让本文件参与插值（见 deploy/README.md）；机密（*_API_KEY）
#         走 compose 的 env_file 注入，无需 --env-file 即生效。
# ============================================================================

# ---- LLM provider（默认 mock，离线确定性，无需任何 key）---------------------
# RAGSPINE_PROVIDER=anthropic            # mock | anthropic（默认 mock）
# RAGSPINE_MODEL=claude-sonnet-4-5       # 仅 anthropic；留注释＝用代码内置默认模型
# RAGSPINE_BASE_URL=https://your-gateway # 企业网关/代理（仅 anthropic）
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx      # provider=anthropic 时必填（anthropic SDK 自行从环境读取）
# OPENAI_API_KEY=sk-xxxxxxxx             # 仅 RAGSPINE_EMBEDDING=openai 时需要

# ---- 向量存储后端（默认 sqlite_vec；profile 切换见 deploy/README.md）----------
# RAGSPINE_VECTOR_STORE=pgvector         # none | in_process | sqlite_vec | pgvector | qdrant
# RAGSPINE_EMBEDDING=openai              # none | deterministic | openai（默认 none＝纯 BM25，无语义向量）
# RAGSPINE_PERSISTENCE_POLICY=default    # default（隔离优先，RESTRICTED 不落盘）| persist_everything
# RAGSPINE_PG_URL=postgresql://ragspine:ragspine@postgres:5432/ragspine  # pgvector 用；pgvector adapter 直接读环境（非 ServiceConfig 旋钮）；compose 已默认指向内置 postgres
# RAGSPINE_PG_PASSWORD=ragspine          # compose-only 插值：仅喂内置 postgres 容器密码（不进 ServiceConfig），默认 ragspine；改了须同步上一行 URL

# ---- 其它可选项 -------------------------------------------------------------
# RAGSPINE_REFERENCE_DATE=2024-12-31     # ISO 日期，影响 real-time/过期判定（留注释＝不固定参考日）
# RAGSPINE_FAQ_SOURCE=/var/lib/ragspine/faq.json     # FAQ 短路 JSON 路径（留注释＝空缓存）
# RAGSPINE_COMPANY_PROFILE=/app/config/company.toml  # 公司画像 TOML（留注释＝用 config/company.example.toml 约定）

# ---- 基础设施路径（compose 已写入 environment 指向命名卷 /var/lib/ragspine；一般无需在此覆盖）----
# RAGSPINE_REDIS_URL=redis://redis:6379/0
# RAGSPINE_DB_PATH=/var/lib/ragspine/fact_metric.db
# RAGSPINE_CHUNK_DB_PATH=/var/lib/ragspine/narrative.db
# RAGSPINE_MAPPING_DB_PATH=/var/lib/ragspine/mapping.db
# RAGSPINE_QUEUE_DB_PATH=/var/lib/ragspine/review_queue.db
# RAGSPINE_MANIFEST_DB_PATH=/var/lib/ragspine/manifest.db
# RAGSPINE_ALLOWED_UPLOAD_ROOT=/var/lib/ragspine/uploads
